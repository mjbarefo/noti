def cmd_ask(a) -> int:
    cfg = load_config()
    buttons = [b for b in a.buttons.split(",") if b] or ["OK"]
    timeout = a.timeout if a.timeout is not None else cfg["toast"]["ask_timeout_seconds"]
    corner = a.corner or cfg["toast"]["corner"]
    slot = acquire_slot()
    try:
        rc, label = toast_ask(a.title, a.message, buttons, timeout, corner, slot,
                              hotkeys=bool(cfg["toast"].get("hotkeys", True)),
                              kind=a.kind, project=a.project)
    except FileNotFoundError as e:
        print(f"noti: {e}", file=sys.stderr)
        return 1
    finally:
        release_slot(slot)
    if label:
        print(label)
    return rc


def cmd_notify(a) -> int:
    cfg = load_config()
    timeout = a.timeout if a.timeout is not None else cfg["toast"]["summary_timeout_seconds"]
    try:
        toast_summary(a.title, a.body, timeout, a.corner or cfg["toast"]["corner"],
                      kind=a.kind, footer=a.footer)
    except FileNotFoundError as e:
        print(f"noti: {e}", file=sys.stderr)
        return 1
    return 0


def cmd_hook(a) -> int:
    try:
        payload = json.load(sys.stdin)
    except Exception as e:
        debug(f"bad stdin: {e}")
        return 0                                  # can't parse -> never block
    try:
        if a.event == "pretooluse":
            return hook_pretooluse(payload)
        if a.event == "stop":
            return hook_stop(payload)
    except Exception as e:
        debug(f"hook crash: {e}")                 # a noti bug must not break the session
        return 0
    return 0


def cmd_decide(a) -> int:
    """Dry-run the policy on a PreToolUse JSON from stdin. Never shows a toast."""
    payload = json.load(sys.stdin)
    print(json.dumps(evaluate(payload, load_config()), indent=2))
    return 0


def _binary_archs(path: Path):
    """Arch slices in a Mach-O binary, via `lipo -archs`. [] if unknowable."""
    lipo = shutil.which("lipo")
    if not lipo or not path.exists():
        return []
    try:
        r = subprocess.run([lipo, "-archs", str(path)], capture_output=True, text=True)
        return r.stdout.split() if r.returncode == 0 else []
    except Exception:
        return []


def cmd_build(a) -> int:
    swiftc = shutil.which("swiftc")
    if not swiftc:
        print("error: swiftc not found. Install Xcode Command Line Tools: xcode-select --install",
              file=sys.stderr)
        return 1
    BINARY.parent.mkdir(parents=True, exist_ok=True)
    pid = os.getpid()
    scratch = []                       # every temp we make, cleaned no matter what

    def compile_to(target: str, tag: str):
        out = BINARY.with_name(f".noti-toast.{tag}.{pid}")
        scratch.append(out)
        ok = subprocess.run([swiftc, "-O", "-target", target,
                             str(SWIFT_SRC), "-o", str(out)]).returncode == 0
        return out if ok else None

    def finish(built: Path) -> int:
        # atomic swap: the LIVE binary is never a half-written file a hook execs
        os.replace(built, BINARY)
        print(f"ok — {BINARY} [{' '.join(_binary_archs(BINARY)) or 'single-arch'}]")
        return 0

    try:
        print(f"building {BINARY} (universal, macOS {MACOS_FLOOR}+) ...")
        slices = [compile_to(f"{arch}-apple-macosx{MACOS_FLOOR}", arch)
                  for arch in ("arm64", "x86_64")]
        lipo = shutil.which("lipo")
        if all(slices) and lipo:
            fat = BINARY.with_name(f".noti-toast.fat.{pid}")
            scratch.append(fat)
            if subprocess.run([lipo, "-create", *[str(s) for s in slices],
                               "-o", str(fat)]).returncode == 0:
                return finish(fat)
        # Fallback: a toolchain that can't cross-compile (missing arch SDK slice
        # or no lipo) still gets a working binary — native-only, but pinned to
        # the same floor. Never leave the user without a toast binary.
        host = platform.machine() or "x86_64"
        print(f"note: universal build unavailable — building {host}-only.", file=sys.stderr)
        native = compile_to(f"{host}-apple-macosx{MACOS_FLOOR}", "native")
        if native:
            return finish(native)
        print("error: swift build failed.", file=sys.stderr)
        return 1
    finally:
        for t in scratch:
            with contextlib.suppress(Exception):
                Path(t).unlink(missing_ok=True)


def _hook_block(payload_cmd: str, matcher=None, timeout=None):
    entry = {"hooks": [{"type": "command", "command": payload_cmd}]}
    if matcher is not None:
        entry["matcher"] = matcher
    if timeout is not None:
        entry["hooks"][0]["timeout"] = timeout
    return entry


def cmd_install(a) -> int:
    if not BINARY.exists() and cmd_build(a) != 0:
        return 1
    cfg = load_config()
    if a.project:
        target = Path(a.project).resolve() / ".claude" / "settings.json"
    else:
        target = Path.home() / ".claude" / "settings.json"

    py = shlex.quote(sys.executable or "python3")
    script = shlex.quote(str(Path(__file__).resolve()))
    pre_cmd = f"{py} {script} hook pretooluse"
    stop_cmd = f"{py} {script} hook stop"
    matcher = "|".join(cfg["approval"]["governed_tools"]) + ("|mcp__.*" if cfg["approval"]["govern_mcp"] else "")
    if cfg["approval"].get("surface_questions", True):
        matcher += "|AskUserQuestion"
    if cfg["approval"].get("surface_plans", True):
        matcher += "|ExitPlanMode"
    pre_timeout = int(cfg["toast"]["ask_timeout_seconds"]) + 30

    target.parent.mkdir(parents=True, exist_ok=True)
    if target.exists():
        try:
            with open(target) as f:
                data = json.load(f)
        except Exception as e:
            print(f"error: {target} is not valid JSON ({e}); fix it before installing.", file=sys.stderr)
            return 1
        if not isinstance(data, dict):
            print(f"error: {target} is not a JSON object.", file=sys.stderr)
            return 1
    else:
        data = {}
    hooks = data.setdefault("hooks", {})

    def already(event):
        return any("noti" in h.get("command", "")
                   for blk in hooks.get(event, []) for h in blk.get("hooks", []))

    if already("PreToolUse") or already("Stop"):
        print("noti hooks already present — nothing to do (run `noti uninstall` first to refresh).")
        return 0

    if target.exists():                                   # back up only when we're actually writing
        backup = target.with_suffix(f".json.noti-backup-{int(time.time())}")
        shutil.copy2(target, backup)
        print(f"backed up {target} -> {backup}")

    hooks.setdefault("PreToolUse", []).append(_hook_block(pre_cmd, matcher=matcher, timeout=pre_timeout))
    hooks.setdefault("Stop", []).append(_hook_block(stop_cmd))
    atomic_write_json(target, data)
    print(f"installed noti hooks into {target}")
    print(f"  PreToolUse matcher: {matcher}")
    print("Start a new `claude` session (or /hooks reload) for it to take effect.")
    return 0


def cmd_uninstall(a) -> int:
    target = (Path(a.project).resolve() / ".claude" / "settings.json") if a.project \
        else Path.home() / ".claude" / "settings.json"
    data = read_json(target, None)
    if not data or "hooks" not in data:
        print(f"no hooks in {target}")
        return 0
    removed = 0
    for event in ("PreToolUse", "Stop"):
        blocks = data["hooks"].get(event, [])
        kept = []
        for blk in blocks:
            if any("noti" in h.get("command", "") for h in blk.get("hooks", [])):
                removed += 1
            else:
                kept.append(blk)
        if kept:
            data["hooks"][event] = kept
        else:
            data["hooks"].pop(event, None)
    atomic_write_json(target, data)
    print(f"removed {removed} noti hook block(s) from {target}")
    return 0


def _mac_ge(ver: str, floor: str) -> bool:
    """True if macOS version string `ver` is at least `floor` (major.minor).
    Unknown/unparseable → True, so doctor never raises a spurious floor alarm."""
    def parse(s):
        out = []
        for p in s.split(".")[:2]:
            try:
                out.append(int(p))
            except ValueError:
                return None
        return (tuple(out) + (0, 0))[:2] if out else None
    a, b = parse(ver), parse(floor)
    return True if a is None or b is None else a >= b


def cmd_doctor(a) -> int:
    ok = True
    def line(label, good, detail=""):
        nonlocal ok
        ok = ok and good
        print(f"  [{'OK' if good else '!!'}] {label}{(' — ' + detail) if detail else ''}")

    print(f"noti doctor — v{VERSION}")

    # 1. Host floor — noti is macOS-only and the toast APIs need macOS 11+.
    mac = platform.mac_ver()[0]
    line(f"macOS >= {MACOS_FLOOR}", _mac_ge(mac, MACOS_FLOOR), mac or "not macOS")
    pv = sys.version_info
    line("python >= 3.9", (pv.major, pv.minor) >= (3, 9), f"{pv.major}.{pv.minor}.{pv.micro}")
    line("~/.claude present", (Path.home() / ".claude").is_dir(), str(Path.home() / ".claude"))

    # 2. Toolchain + binary. Arch mismatch is the failure a stranger hits after
    #    copying someone else's build (Intel binary on Apple Silicon, or vice
    #    versa); a binary older than its source means a stale `./noti build`.
    line("swiftc available", shutil.which("swiftc") is not None, shutil.which("swiftc") or "missing")
    line("toast binary built", BINARY.exists(), str(BINARY) if BINARY.exists() else "run `./noti build`")
    if BINARY.exists():
        archs, host = _binary_archs(BINARY), platform.machine()
        line("binary runs on this arch", (not archs) or host in archs,
             f"{' '.join(archs) or 'unknown'} · host {host}"
             + ("" if (not archs or host in archs) else " — run `./noti build`"))
        if SWIFT_SRC.exists():
            stale = BINARY.stat().st_mtime < SWIFT_SRC.stat().st_mtime
            line("binary up to date", not stale,
                 "source newer than binary — run `./noti build`" if stale else "")

    # 3. Hooks — installed, pointing at a live clone (this one), matcher current.
    g = Path.home() / ".claude" / "settings.json"
    gd = read_json(g, {}) or {}
    pre = gd.get("hooks", {}).get("PreToolUse", [])
    noti_cmd = next((h.get("command", "") for blk in pre for h in blk.get("hooks", [])
                     if "noti" in h.get("command", "")), "")
    has = bool(noti_cmd)
    line("hooks installed (global)", has, "run `noti install` to wire up" if not has else str(g))
    cfg = load_config()
    if has:
        # The installed hook runs a specific `noti` script path. A moved/deleted
        # clone leaves that path dangling (hooks fail OPEN, so silently — doctor
        # is the only place it surfaces); a path into a DIFFERENT clone means
        # this doctor run isn't describing what actually executes.
        try:
            toks = shlex.split(noti_cmd)
        except Exception:
            toks = noti_cmd.split()
        script = next((t for t in toks if os.path.basename(t) == "noti"), "")
        sp = Path(script) if script else None
        alive = bool(sp) and sp.exists()
        line("hook script exists", alive,
             "" if alive else
             f"{script or 'no script path in hook'} — clone moved/deleted; `noti install` from its new home")
        if alive:
            here = (HERE / "noti").resolve()
            line("hook runs this clone", sp.resolve() == here,
                 f"hooks run {sp.resolve()}, not this clone" if sp.resolve() != here else "")
        # an install predating question/plan surfacing has a matcher that
        # filters those events out before noti ever runs — flag the drift
        matcher = next((blk.get("matcher", "") for blk in pre
                        if any("noti" in h.get("command", "") for h in blk.get("hooks", []))), "")
        stale = (cfg["approval"].get("surface_questions", True) and "AskUserQuestion" not in matcher) or \
                (cfg["approval"].get("surface_plans", True) and "ExitPlanMode" not in matcher)
        line("hook matcher current", not stale,
             "matcher predates question/plan surfacing — `noti uninstall && noti install`" if stale else "")
    print(f"  governed: {', '.join(cfg['approval']['governed_tools'])}"
          f"{' + mcp__*' if cfg['approval']['govern_mcp'] else ''}")
    print(f"  ask timeout: {cfg['toast']['ask_timeout_seconds']}s · rule scope: {cfg['approval']['rule_scope']}")
    return 0 if ok else 1


def cmd_version(a) -> int:
    print(f"noti {VERSION}")
    return 0

# ---------------------------------------------------------------------------
# argparse
# ---------------------------------------------------------------------------

def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(prog="noti", description=__doc__,
                                formatter_class=argparse.RawDescriptionHelpFormatter)
    # top-level --version fires during parse (before the required-subcommand
    # check), so `noti --version` works without naming a subcommand
    p.add_argument("--version", action="version", version=f"noti {VERSION}")
    sub = p.add_subparsers(dest="cmd", required=True)

    a = sub.add_parser("ask", help="blocking Yes/Always/No toast (prints label, exit=index)")
    a.add_argument("--title", default="")
    a.add_argument("--message", default="")
    a.add_argument("--buttons", default="Yes,No")
    a.add_argument("--timeout", type=float, default=None)
    a.add_argument("--corner", default=None)
    a.add_argument("--kind", default="", help="run|edit|fetch|mcp|note|question|plan — icon chip; run/edit/fetch/mcp get a mono message")
    a.add_argument("--project", default="", help="eyebrow line above the title")
    a.set_defaults(fn=cmd_ask)

    n = sub.add_parser("notify", help="non-blocking auto-dismissing summary toast")
    n.add_argument("--title", default="")
    n.add_argument("--body", default="")
    n.add_argument("--timeout", type=float, default=None)
    n.add_argument("--corner", default=None)
    n.add_argument("--kind", default="note", help="icon chip: run|edit|fetch|mcp|note|question|plan")
    n.add_argument("--footer", default="", help="small monospaced footer line")
    n.set_defaults(fn=cmd_notify)

    h = sub.add_parser("hook", help="Claude Code hook adapter (reads JSON on stdin)")
    h.add_argument("event", choices=["pretooluse", "stop"])
    h.set_defaults(fn=cmd_hook)

    d = sub.add_parser("decide", help="dry-run the policy on stdin JSON (no toast)")
    d.set_defaults(fn=cmd_decide)

    b = sub.add_parser("build", help="compile the Swift toast binary")
    b.set_defaults(fn=cmd_build)

    i = sub.add_parser("install", help="wire up the Claude Code hooks")
    grp = i.add_mutually_exclusive_group()
    grp.add_argument("--global", dest="glob", action="store_true", help="install into ~/.claude (default)")
    grp.add_argument("--project", metavar="DIR", help="install into DIR/.claude instead")
    i.set_defaults(fn=cmd_install)

    u = sub.add_parser("uninstall", help="remove the noti hooks")
    u.add_argument("--project", metavar="DIR")
    u.set_defaults(fn=cmd_uninstall)

    sub.add_parser("doctor", help="check install state").set_defaults(fn=cmd_doctor)
    sub.add_parser("version", help="print version").set_defaults(fn=cmd_version)
    return p


def main() -> int:
    args = build_parser().parse_args()
    if not hasattr(args, "project"):
        args.project = None
    return args.fn(args) or 0


if __name__ == "__main__":
    sys.exit(main())
