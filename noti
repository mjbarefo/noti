def cmd_pet(a) -> int:
    cfg = load_config()
    if a.stop:
        return stop_pet(cfg)
    if not (cfg.get("pet") or {}).get("enabled", False):
        print("noti pet is disabled; set pet.enabled: true in config to opt in.", file=sys.stderr)
        return 1
    # One critter, one question: refuse a second launch instead of orphaning the
    # first (its pid file would be clobbered, leaving it unreachable from --stop
    # and uninstall while a duplicate stacks pixel-perfectly on the same corner).
    running = pet_is_running()
    if running is not None:
        print(f"noti pet is already running (pid {running})")
        return 0
    try:
        pid = launch_pet(cfg)
    except (FileNotFoundError, RuntimeError) as e:
        print(f"noti: {e}", file=sys.stderr)
        return 1
    print(f"noti pet started (pid {pid})")
    return 0


def cmd_hook(a) -> int:
    try:
        payload = json.load(sys.stdin)
    except Exception as e:
        debug(f"bad stdin: {e}")
