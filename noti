def debug(msg: str) -> None:
    if os.environ.get("NOTI_DEBUG"):
        try:
            CONFIG_HOME.mkdir(parents=True, exist_ok=True)
            with open(LOG_FILE, "a") as f:
                f.write(f"{time.strftime('%H:%M:%S')} {msg}\n")
        except Exception:
            pass


def load_config() -> dict:
    cfg = json.loads(json.dumps(DEFAULT_CONFIG))  # deep copy
    for path in (HERE / "noti.config.json", CONFIG_HOME / "config.json"):
        data = read_json(path, None)
        if isinstance(data, dict):
            _deep_merge(cfg, data)
    return cfg


def _deep_merge(base: dict, over: dict) -> None:
    for k, v in over.items():
        if isinstance(v, dict) and isinstance(base.get(k), dict):
            _deep_merge(base[k], v)
        else:
            base[k] = v


def read_json(path: Path, default):
    try:
        with open(path) as f:
            return json.load(f)
    except Exception:
        return default


def atomic_write_json(path: Path, data) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    tmp = path.with_suffix(path.suffix + f".tmp.{os.getpid()}")
    with open(tmp, "w") as f:
        json.dump(data, f, indent=2)
        f.write("\n")
    os.replace(tmp, path)


@contextlib.contextmanager
def locked(name: str):
    CONFIG_HOME.mkdir(parents=True, exist_ok=True)
    lock = open(CONFIG_HOME / name, "w")
    try:
        fcntl.flock(lock, fcntl.LOCK_EX)
        yield
    finally:
        fcntl.flock(lock, fcntl.LOCK_UN)
        lock.close()


def trunc(s: str, n: int) -> str:
    s = s.strip()
    return s if len(s) <= n else s[: n - 1].rstrip() + "…"


def home_short(p: str) -> str:
    try:
        return "~/" + str(Path(p).resolve().relative_to(Path.home()))
    except Exception:
        return p

# ---------------------------------------------------------------------------
# toast invocation
# ---------------------------------------------------------------------------

def _toast_env(timeout: float, slot, corner: str, hotkeys: bool = True,
               kind: str = "", project: str = "", footer: str = "") -> dict:
    env = dict(os.environ)
    env["NOTI_TIMEOUT"] = str(timeout)
    env["NOTI_CORNER"] = corner
    env["NOTI_HOTKEYS"] = "1" if hotkeys else "0"
    if slot is not None:
        env["NOTI_SLOT"] = str(slot)
        # lets the toast publish its height, heartbeat its claim, and re-pack
        # the column when a neighbour dismisses
        env["NOTI_SLOT_DIR"] = str(SLOT_DIR)
    if kind:
        env["NOTI_KIND"] = kind        # tints the icon chip; mono message
    if project:
        env["NOTI_PROJECT"] = project  # eyebrow line: which session is asking
    if footer:
        env["NOTI_FOOTER"] = footer    # small mono footer (summary: the tally)
    return env


def toast_ask(title, message, buttons, timeout, corner, slot, hotkeys=True,
              kind="", project=""):
    """Blocking. Returns (returncode, label). returncode 124 == timed out."""
    if not BINARY.exists():
        raise FileNotFoundError(f"{BINARY} missing — run `noti build`")
    proc = subprocess.run(
        [str(BINARY), "ask", title, message, *buttons],
        capture_output=True, text=True,
        env=_toast_env(timeout, slot, corner, hotkeys, kind, project),
    )
    return proc.returncode, proc.stdout.strip()


def toast_summary(title, body, timeout, corner, kind="note", footer=""):
    """Non-blocking. Spawns a detached toast that auto-dismisses, then returns."""
    if not BINARY.exists():
        raise FileNotFoundError(f"{BINARY} missing — run `noti build`")
    # summaries join the same slot column as ask toasts, so an end-of-turn
    # card can never land on top of another session's pending approval. The
    # detached toast owns the release (it deletes its slot file on exit);
    # the stale sweep reclaims the slot if it never launches.
    slot = acquire_slot()
    try:
        subprocess.Popen(
            [str(BINARY), "summary", title, body],
            env=_toast_env(timeout, slot, corner, kind=kind, footer=footer),
            stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
            start_new_session=True,
        )
    except Exception:
        release_slot(slot)
        raise


def acquire_slot(max_slots: int = 8) -> int:
    """Claim the lowest free vertical slot so concurrent toasts don't overlap.

    The slot file is created EMPTY: the toast binary itself writes its pixel
    height into it (and heartbeats it), so sibling toasts can stack below the
    real column of cards rather than guessing every card is their own height.
    Anything numeric in the file must be a height — never write a pid here."""
    SLOT_DIR.mkdir(parents=True, exist_ok=True)
    for i in range(max_slots):
        p = SLOT_DIR / f"slot-{i}"
        try:
            os.close(os.open(str(p), os.O_CREAT | os.O_EXCL | os.O_WRONLY))
            return i
        except FileExistsError:
            # reclaim a stale slot (>2 min: live toasts heartbeat their file
            # every 0.4s, so anything older is a corpse) and claim it
            try:
                if time.time() - p.stat().st_mtime > 120:
                    p.unlink(missing_ok=True)
                    os.close(os.open(str(p), os.O_CREAT | os.O_EXCL | os.O_WRONLY))
                    return i
            except Exception:
                pass
    return 0  # all busy: overlap rather than fail


def release_slot(i) -> None:
    if i is None:
        return
    try:
        (SLOT_DIR / f"slot-{i}").unlink(missing_ok=True)
    except Exception:
        pass

# ---------------------------------------------------------------------------
# permission rules: matching + minting (must round-trip with each other)
# ---------------------------------------------------------------------------

def settings_files(cwd: str):
    return [
        Path.home() / ".claude" / "settings.json",
        Path(cwd) / ".claude" / "settings.json",
        Path(cwd) / ".claude" / "settings.local.json",
    ]


def load_patterns(cwd: str, kind: str):
    """kind = 'allow' | 'deny'. Merge across the settings hierarchy."""
    out = []
    for f in settings_files(cwd):
        data = read_json(f, {})
        perms = (data or {}).get("permissions", {})
        for p in perms.get(kind, []) or []:
            if isinstance(p, str):
                out.append(p)
    return out


def abs_rule_path(path: str) -> str:
    """Claude writes absolute paths with a leading double slash: //Users/..."""
    return "/" + os.path.abspath(os.path.expanduser(path))  # '/' + '/Users/..' -> '//Users/..'


def make_rule(tool: str, tinput: dict, cfg: dict):
    """Mint a permissions.allow pattern for an 'Always' grant. None if undecidable."""
    if tool == "Bash":
        cmd = (tinput.get("command") or "").strip()
        if not cmd:
            return None
        if cmd.endswith("*"):
            # Claude's engine reads a trailing * as a PREFIX rule, so minting
            # "Bash(rm -rf node_modules/*)" would allow far more than the user
            # approved. Refuse — 'Always' quietly degrades to a one-time 'Yes'.
            return None
        if cfg["approval"]["bash_always_mode"] == "prefix":
            head = " ".join(cmd.split()[:2])
            return f"Bash({head}:*)"
        return f"Bash({cmd})"  # exact: safe default, never broadens a verb
    if tool in EDIT_TOOLS:
        path = tinput.get("file_path") or tinput.get("notebook_path")
        if not path:
            return None
        name = "Write" if tool == "Write" else "Edit"
        return f"{name}({abs_rule_path(path)})"
    if tool == "WebFetch":
        host = urlparse(tinput.get("url", "")).hostname
        return f"WebFetch(domain:{host})" if host else None
    if tool.startswith("mcp__"):
        return tool  # MCP grants are by exact tool id
    return None


def _bash_match(cmd: str, inner: str, broad: bool = False) -> bool:
    for suf in (":*", " *"):     # Claude's two word-boundary prefix spellings
        if inner.endswith(suf):
            prefix = inner[:-2].rstrip()
            return cmd == prefix or cmd.startswith(prefix + " ")   # 'git log' !~ 'git logger'
    if broad and inner.endswith("*"):
        # DENY matching (broad=True) must be at least as broad as Claude's own
        # engine, or a deny rule noti fails to match is silently BYPASSED: noti
        # returns no deny, then auto-allows via the safe-list, and a PreToolUse
        # 'allow' overrides Claude's deny enforcement. Claude reads a bare
        # trailing * as a raw prefix wildcard (Bash(ls*) matches 'lsof', not just
        # 'ls '), so mirror that. Over-denying is the safe direction here.
        return cmd.startswith(inner.rstrip("*"))
    return cmd == inner          # ALLOW matching (broad=False) keeps a bare trailing
                                 # * LITERAL: Claude reads it as a prefix, but treating
                                 # it that way would broaden what an allow rule covers —
                                 # stricter is safe there (worst case: an extra toast).


def _glob_rx(pat: str) -> str:
    rx = re.escape(pat)
    return rx.replace(r"\*\*/", r"(?:.*/)?").replace(r"\*\*", ".*").replace(r"\*", "[^/]*")


def _path_match(path: str, inner: str, cwd: str) -> bool:
    # Claude's path anchors: //abs, ~/home, /project-root, bare = relative.
    # The anchor base (home/cwd) is trusted literal text and is regex-escaped
    # SEPARATELY from the user-authored glob: escaping the joined string would
    # let a literal '*' in a real directory name re-expand into a wildcard.
    if inner.startswith("//"):
        rx = _glob_rx(inner[1:])
    elif inner.startswith("~"):
        rx = re.escape(str(Path.home())) + _glob_rx(inner[1:])
    elif inner.startswith("/"):
        rx = re.escape(cwd.rstrip("/")) + _glob_rx(inner)
    else:
        rx = re.escape(cwd.rstrip("/")) + "/" + _glob_rx(inner)
    target = os.path.abspath(os.path.expanduser(path))
    return re.fullmatch(rx, target) is not None


def _host_match(host: str, dom: str) -> bool:
    if dom.startswith("*."):
        bare = dom[2:]
        return host == bare or host.endswith("." + bare)
    return host == dom or host.endswith("." + dom)


def pattern_matches(tool: str, tinput: dict, pat: str, cwd: str = "", broad: bool = False) -> bool:
    # broad=True is DENY matching: widen a bare trailing * in a Bash rule to a
    # prefix (see _bash_match) so noti can't under-match and bypass a deny.
    cwd = cwd or os.getcwd()
    if "(" not in pat:
        if pat == tool:
            return True
        # Claude server-scoped MCP rule: `mcp__server` covers every `mcp__server__tool`
        if pat.startswith("mcp__") and tool.startswith(pat + "__"):
            return True
        # Claude MCP wildcard rule: `mcp__server__get_*`
        if pat.startswith("mcp__") and "*" in pat:
            return fnmatch.fnmatchcase(tool, pat)
        return False
    name, _, rest = pat.partition("(")
    # strip ONE closing paren — rstrip(")") would eat a command's own, e.g. `git log $(...)`
    inner = rest[:-1] if rest.endswith(")") else rest
    name_ok = (name == tool) or (name == "Edit" and tool in EDIT_TOOLS)
    if not name_ok:
        return False
    if tool == "Bash":
        return _bash_match((tinput.get("command") or "").strip(), inner, broad)
    if tool in EDIT_TOOLS:
        return _path_match(tinput.get("file_path") or tinput.get("notebook_path") or "", inner, cwd)
    if tool == "WebFetch":
        if inner.startswith("domain:"):
            return _host_match(urlparse(tinput.get("url", "")).hostname or "", inner[len("domain:"):])
        return False
    return False


def matches_any(tool: str, tinput: dict, patterns, cwd: str = "", broad: bool = False) -> bool:
    return any(pattern_matches(tool, tinput, p, cwd, broad) for p in patterns)

# ---------------------------------------------------------------------------
# policy
# ---------------------------------------------------------------------------

_BASH_META = set("$`;|&<>(){}\n")
# Flags that turn an otherwise read-only verb into a write/delete/exec. A safe
# verb carrying any of these is NOT auto-allowed — defence-in-depth in case the
# safelist is ever widened (e.g. someone re-adds find or rg via config).
#   --output / --ext-diff: git log/diff/show honour these — `git diff
#     --output=FILE` writes an arbitrary path, `--ext-diff` runs an external
#     diff driver. Only the long forms are listed: git has no short `-o`, and a
#     bare `-o` would collide with `grep -o` (read-only, and safe-listed).
# The check is token-based (see is_safe_bash): it catches `--output FILE` and
# `--output=FILE`, but NOT a value glued to a short flag (e.g. `-oFILE`). That
# residual is why a command whose only write vector is a short flag (tree -o) is
# dropped from the safe-list outright rather than relying on flag-blocking.
_BASH_DANGEROUS_FLAGS = ("-exec", "-execdir", "-delete", "-fls", "-fprint",
                         "-fprintf", "-ok", "-okdir", "--pre", "--search-zip",
                         "--output", "--ext-diff")

# MCP method tokens that imply a state change or code execution — block auto-allow
# if any appears anywhere in the method name.
MCP_MUTATING_TOKENS = {
    # state change
    "create", "update", "delete", "send", "write", "remove", "drop", "replace",
    "purge", "add", "move", "copy", "insert", "set", "modify", "apply", "label",
    "unlabel", "respond", "archive", "trash", "upload", "edit", "patch", "post",
    "put", "rename", "clear", "reset", "merge", "truncate", "cancel", "approve",
    "share", "import", "export", "transfer", "submit",
    # execution / lifecycle
    "exec", "execute", "run", "invoke", "call", "push", "deploy", "publish",
    "trigger", "schedule", "enable", "disable", "start", "stop", "grant", "revoke",
}


def is_safe_bash(command: str, cfg: dict) -> bool:
    cmd = (command or "").strip()
    if not cmd or any(c in _BASH_META for c in cmd):
        return False
    # Tokenize the way the SHELL does, not with a naive whitespace split. Quotes
    # and backslashes are NOT in _BASH_META, so `git log --out"put"=/tmp/x` and
    # `git log --out\put=x` clear the metachar gate — yet bash reassembles them
    # into `--output=...` and writes the file. cmd.split() sees one opaque token
    # that never matches `--output`; shlex.split (POSIX) applies the same quote/
    # backslash removal bash does — on a string already free of $ ` ; | & < > ( )
    # { } and newline — so the dangerous-flag check sees the REAL argv. Unbalanced
    # quotes raise ValueError; fail closed (bash would error on it too — an extra
    # toast at worst).
    try:
        toks = shlex.split(cmd)
    except ValueError:
        return False
    if any(t == f or t.startswith(f + "=") for t in toks for f in _BASH_DANGEROUS_FLAGS):
        return False
    # The safe-verb match stays on the raw command: quote-splicing a verb
    # (`l"s"`) only makes it FAIL to match a safe prefix, which is the strict,
    # safe direction (an extra toast, never a spurious allow).
    return any(cmd == s or cmd.startswith(s + " ") for s in cfg["approval"]["bash_safe_commands"])


def is_read_only_mcp(tool: str, cfg: dict) -> bool:
    """Opt-in only. A call auto-allows iff its server is on mcp_autoallow_servers
    AND its method starts with a read verb AND carries no mutating token. With the
    default (empty) allowlist, every governed MCP tool prompts."""
    servers = cfg["approval"].get("mcp_autoallow_servers")
    if not isinstance(servers, list) or not servers:   # a stray string must not become a substring test
        return False
    parts = tool.split("__")
    if len(parts) < 3:
        return False
    server, method = parts[1], "__".join(parts[2:]).lower()
    if server not in servers:
        return False
    tokens = re.split(r"[_\-]+", method)
    if any(t in MCP_MUTATING_TOKENS for t in tokens):
        return False
    return bool(tokens) and tokens[0] in set(cfg["approval"]["mcp_read_verbs"])


def is_governed(tool: str, cfg: dict) -> bool:
    if tool in cfg["approval"]["governed_tools"]:
        return True
    return bool(cfg["approval"]["govern_mcp"]) and tool.startswith("mcp__")


def render_call(tool: str, tinput: dict):
    """-> (kind, title, message). kind drives the toast's icon chip (tint +
    glyph) and monospace treatment: run | edit | fetch | mcp | tool."""
    if tool == "Bash":
        return "run", "Run command", trunc(tinput.get("command", ""), 220)
    if tool in EDIT_TOOLS:
        path = tinput.get("file_path") or tinput.get("notebook_path") or "?"
        verb = "Write" if tool == "Write" else "Edit"
        return "edit", f"{verb} file", home_short(path)
    if tool == "WebFetch":
        return "fetch", "Fetch URL", trunc(tinput.get("url", ""), 220)
    if tool.startswith("mcp__"):
        parts = tool.split("__")
        server = parts[1] if len(parts) > 1 else "mcp"
        method = "_".join(parts[2:]) if len(parts) > 2 else tool
        return "mcp", f"{server}: {method}", trunc(json.dumps(tinput, ensure_ascii=False), 200)
    return "tool", tool, trunc(json.dumps(tinput, ensure_ascii=False), 200)


def render_question(tinput: dict) -> dict:
    """AskUserQuestion -> decision dict. One single-select question with 2-3
    options becomes a 'question' toast whose buttons ARE the options — the
    common case, answered without touching the terminal. Anything richer
    (several questions, multiSelect, 4+ options — and the terminal UI also
    owns free-text "Other") becomes a non-blocking 'notice' so the human
    knows the session is waiting on them."""
    qs = [q for q in (tinput.get("questions") or []) if isinstance(q, dict)]
    if len(qs) == 1 and not qs[0].get("multiSelect"):
        q = qs[0]
        options = [o.get("label", "") if isinstance(o, dict) else str(o)
                   for o in (q.get("options") or [])]
        options = [o for o in options if o]
        if 2 <= len(options) <= 3:
            header = str(q.get("header") or "").strip()
            return {"action": "question",
                    "title": f"Claude asks — {header}" if header else "Claude asks",
                    "message": trunc(str(q.get("question") or ""), 220),
                    # full texts, not the truncated button labels: `answers`
                    # must be keyed by the exact question, valued by the exact
                    # option label, or Claude Code won't recognise the answer
                    "question": str(q.get("question") or ""),
                    "options": options,
                    "buttons": [trunc(o, 16) for o in options]}
    n = len(qs)
    first = trunc(str(qs[0].get("question") or ""), 160) if qs else ""
    return {"action": "notice", "kind": "question",
            "title": "Claude has a question" if n <= 1 else f"Claude has {n} questions",
            "message": first + (f"  (+{n - 1} more)" if n > 1 else ""),
            "footer": "answer in the terminal"}


def render_plan(tinput: dict) -> dict:
    """ExitPlanMode -> decision dict. The toast is a fast-path Approve plus a
    deliberate View that hands off to the terminal's full plan UI — a corner
    card must never pretend to show a whole plan."""
    preview = clean_summary(str(tinput.get("plan") or ""), 220)
    return {"action": "plan", "title": "Plan ready for review",
            "message": preview or "Review the plan in the terminal."}


def evaluate(payload: dict, cfg: dict) -> dict:
    """Pure decision. Returns dict with action in
    {allow, deny, defer, prompt} (+ reason / title / message)."""
    # Coerce every field to the type the rest of the function assumes. Claude
    # Code's hook JSON shape has shifted across versions, and a stranger may run
    # an older/newer build: a non-dict tool_input or non-str tool_name must
    # DEGRADE per-decision (defer to Claude's own flow), never traceback. The
    # hook path already fails open, but keeping evaluate() itself total means
    # `noti decide` and any future caller stay robust too.
    if not isinstance(payload, dict):
        return {"action": "defer", "reason": "noti: malformed payload"}
    tool = payload.get("tool_name")
    tool = tool if isinstance(tool, str) else ""
    tinput = payload.get("tool_input")
    tinput = tinput if isinstance(tinput, dict) else {}
    # The known scalar sub-fields feed .strip()/.startswith()/urlparse downstream
    # (is_safe_bash, pattern_matches, make_rule). A non-string one — e.g. a
    # forward-incompatible build sending `command` as a number — would traceback,
    # so normalize them here (copy, don't mutate the caller's dict). `questions`
    # and other structured fields are left as-is; their renderers already guard.
    if any(not isinstance(tinput.get(k), (str, type(None))) for k in _TINPUT_STR_FIELDS):
        tinput = {k: ("" if k in _TINPUT_STR_FIELDS and not isinstance(v, str) else v)
                  for k, v in tinput.items()}
    mode = payload.get("permission_mode") or "default"
    cwd_raw = payload.get("cwd")
    cwd = cwd_raw if isinstance(cwd_raw, str) and cwd_raw else os.getcwd()
    # When the payload omits cwd, os.getcwd() is a guess, not the session's project
    # dir — a relative/project-anchored ALLOW rule would then anchor to the wrong
    # base and could auto-allow a path a deny rule (mis-anchored the same way) was
    # meant to block. Real Claude Code always sends cwd; when it's missing we
    # simply don't honour path-anchored allow rules (fall through to a prompt).
    cwd_known = isinstance(cwd_raw, str) and bool(cwd_raw)

    # 0. Claude-to-human interaction tools are not permission gates — they're
    #    the session waiting on a person (a question to answer, a plan to
    #    review), and they block in EVERY permission mode: a bypass session
    #    still stops on a question, and plan mode is precisely when
    #    ExitPlanMode fires. So they're surfaced before the governed/mode
    #    gates below — but a deny rule keeps its hard-floor guarantee here too.
    surface = {"AskUserQuestion": ("surface_questions", render_question),
               "ExitPlanMode": ("surface_plans", render_plan)}
    if tool in surface:
        flag, render = surface[tool]
        if not cfg["approval"].get(flag, True):
            return {"action": "defer", "reason": f"noti: {flag} off"}
        if matches_any(tool, tinput, load_patterns(cwd, "deny"), cwd, broad=True):
            return {"action": "deny", "reason": "noti: matches a deny rule"}
        d = render(tinput)
        project = os.path.basename(cwd.rstrip("/"))
        d.setdefault("project", project)
        if d["action"] == "notice" and project:
            d["footer"] = f"{project} · {d['footer']}"
        return d

    # 1. Only govern the tools we were asked to.
    if not is_governed(tool, cfg):
        return {"action": "defer", "reason": "noti: ungoverned tool"}

    # 2. Honour an explicit deny rule before ANYTHING else — even before the
    #    bypass/plan/acceptEdits short-circuits. A deny rule is the user's hard
    #    floor; PreToolUse hooks still fire (and may block) in bypass mode, so
    #    noti enforces the deny rather than letting a permissive mode override it.
    if matches_any(tool, tinput, load_patterns(cwd, "deny"), cwd, broad=True):
        return {"action": "deny", "reason": "noti: matches a deny rule"}

    # 3. Respect the user's chosen permission mode (after deny). dontAsk means
    #    "never prompt me" — noti must not toast either. (auto mode falls
    #    through: noti's toast simply replaces the prompt the classifier
    #    would have shown.)
    if mode in ("bypassPermissions", "plan", "dontAsk"):
        return {"action": "defer", "reason": f"noti: {mode} mode"}

    # 4. acceptEdits: Claude already auto-accepts edits — don't nag.
    if mode == "acceptEdits" and tool in EDIT_TOOLS:
        return {"action": "allow", "reason": "noti: acceptEdits mode"}

    # 5. Already allowed (Claude's rules or a prior 'Always') -> allow silently.
    #    NB: must be 'allow', not 'defer' — in default mode a defer would surface
    #    Claude's own terminal prompt, defeating the toast. Gated on a known cwd:
    #    a path-anchored allow rule resolved against a guessed cwd could out-vote a
    #    deny rule mis-anchored the same way, so when cwd is absent we don't
    #    auto-allow via rules (fall through to a prompt — the safe direction).
    if cwd_known and matches_any(tool, tinput, load_patterns(cwd, "allow"), cwd):
        return {"action": "allow", "reason": "noti: already allowed"}

    # 6. Conservative auto-allow surfaces.
    if tool == "Bash" and is_safe_bash(tinput.get("command", ""), cfg):
        return {"action": "allow", "reason": "noti: safe read-only command"}
    if tool.startswith("mcp__") and is_read_only_mcp(tool, cfg):
        return {"action": "allow", "reason": "noti: read-only MCP call"}

    # 7. A genuine human moment.
    kind, title, message = render_call(tool, tinput)
    return {"action": "prompt", "kind": kind, "title": title, "message": message,
            "project": os.path.basename(cwd.rstrip("/"))}

# ---------------------------------------------------------------------------
# per-session tool tally (powers the summary's second line)
# ---------------------------------------------------------------------------

def tally_record(payload: dict) -> None:
    tool = payload.get("tool_name", "")
    tinput = payload.get("tool_input", {}) or {}
    sid = payload.get("session_id", "default")
    path = TALLY_DIR / f"{sid}.json"
    with locked("tally.lock"):
        data = read_json(path, {}) or {}
        data.setdefault("bash", 0)
        data.setdefault("files", [])
        data.setdefault("webfetch", 0)
        data.setdefault("mcp", 0)
        if tool == "Bash":
            data["bash"] += 1
        elif tool in EDIT_TOOLS:
            f = tinput.get("file_path") or tinput.get("notebook_path")
            if f and f not in data["files"]:
                data["files"].append(f)
        elif tool == "WebFetch":
            data["webfetch"] += 1
        elif tool.startswith("mcp__"):
            data["mcp"] += 1
        elif tool == "AskUserQuestion":
            data["questions"] = data.get("questions", 0) + 1
        elif tool == "ExitPlanMode":
            data["plans"] = data.get("plans", 0) + 1
        atomic_write_json(path, data)


def tally_read_and_clear(sid: str):
    path = TALLY_DIR / f"{sid}.json"
    with locked("tally.lock"):
        data = read_json(path, None)
        try:
            path.unlink(missing_ok=True)
        except Exception:
            pass
        # sessions killed before their Stop hook leave tallies behind — sweep them
        try:
            cutoff = time.time() - 48 * 3600
            for p in TALLY_DIR.glob("*.json"):
                if p.stat().st_mtime < cutoff:
                    p.unlink(missing_ok=True)
        except Exception:
            pass
    return data


def format_tally(t) -> str:
    if not t:
        return ""
    bits = []
    if t.get("bash"):
        bits.append(f"ran {t['bash']} command" + ("s" if t["bash"] != 1 else ""))
    nf = len(t.get("files", []))
    if nf:
        bits.append(f"edited {nf} file" + ("s" if nf != 1 else ""))
    if t.get("webfetch"):
        bits.append(f"fetched {t['webfetch']} url" + ("s" if t["webfetch"] != 1 else ""))
    if t.get("mcp"):
        bits.append(f"{t['mcp']} MCP action" + ("s" if t["mcp"] != 1 else ""))
    if t.get("questions"):
        bits.append(f"answered {t['questions']} question" + ("s" if t["questions"] != 1 else ""))
    if t.get("plans"):
        bits.append("approved a plan" if t["plans"] == 1 else f"approved {t['plans']} plans")
    return " · ".join(bits)


def last_message_from_transcript(path: str) -> str:
    """Fallback for older Claude Code versions whose Stop payload lacks
    last_assistant_message: recover it from the session transcript JSONL."""
    best = ""
    try:
        with open(path) as f:
            for line in f:
                try:
                    e = json.loads(line)
                except Exception:
                    continue
                if e.get("type") != "assistant" or e.get("isSidechain"):
                    continue
                content = (e.get("message") or {}).get("content")
                if isinstance(content, str):
                    text = content
                elif isinstance(content, list):
                    text = "\n".join(b.get("text", "") for b in content
                                     if isinstance(b, dict) and b.get("type") == "text")
                else:
                    continue
                if text.strip():
                    best = text
    except Exception:
        pass
    return best


def clean_summary(msg: str, maxc: int) -> str:
    if not msg:
        return ""
    # drop fenced code blocks, then strip light markdown
    msg = re.sub(r"```.*?```", " ", msg, flags=re.DOTALL)
    lines = []
    for ln in msg.splitlines():
        s = ln.strip()
        s = re.sub(r"^#{1,6}\s*", "", s)        # headings
        s = re.sub(r"^[-*]\s+", "• ", s)   # bullets
        s = re.sub(r"[`*_]", "", s)             # inline emphasis/code
        if s:
            lines.append(s)
    return trunc(" ".join(lines), maxc)

# ---------------------------------------------------------------------------
# hook handlers
# ---------------------------------------------------------------------------

def emit_pretool(decision: str, reason: str, updated_input: dict | None = None) -> None:
    out = {
        "hookEventName": "PreToolUse",
        "permissionDecision": decision,
        "permissionDecisionReason": reason,
    }
    # updatedInput (allow only) is how a hook hands Claude Code pre-collected
    # AskUserQuestion answers — the same channel its own permission UI uses.
    # A Claude Code too old to know the field just ignores it and asks in the
    # terminal: degraded, never wrong.
    if updated_input is not None:
        out["updatedInput"] = updated_input
    print(json.dumps({"hookSpecificOutput": out}))


def prompt_question(payload: dict, cfg: dict, d: dict) -> int:
    """Toast a single simple question; the buttons are the options. A click is
    handed back as pre-collected `answers` via updatedInput, so the terminal
    UI never appears. Esc / timeout / any error emits NO decision — the full
    terminal UI (option descriptions, free-text Other) is the fallback."""
    slot = acquire_slot()
    try:
        rc, _ = toast_ask(d["title"], d["message"], d["buttons"],
                          cfg["toast"]["ask_timeout_seconds"], cfg["toast"]["corner"], slot,
                          hotkeys=bool(cfg["toast"].get("hotkeys", True)),
                          kind="question", project=d.get("project", ""))
    except Exception as e:
        debug(f"question toast failed: {e}")
        return 0
    finally:
        release_slot(slot)
    if 0 <= rc < len(d["options"]):
        tinput = dict(payload.get("tool_input") or {})
        tinput["answers"] = {d["question"]: d["options"][rc]}
        tally_record(payload)
        emit_pretool("allow", "noti: question answered from toast", updated_input=tinput)
    return 0


def prompt_plan(payload: dict, cfg: dict, d: dict) -> int:
    """Toast a plan-ready card. Approve is the fast path (Claude proceeds; the
    implementation edits/commands still go through noti's approval toasts).
    View / Esc / timeout emits NO decision — the terminal's plan UI, which can
    actually show the whole plan and take feedback, handles it."""
    slot = acquire_slot()
    try:
        rc, _ = toast_ask(d["title"], d["message"], ["Approve", "View"],
                          cfg["toast"]["ask_timeout_seconds"], cfg["toast"]["corner"], slot,
                          hotkeys=bool(cfg["toast"].get("hotkeys", True)),
                          kind="plan", project=d.get("project", ""))
    except Exception as e:
        debug(f"plan toast failed: {e}")
        return 0
    finally:
        release_slot(slot)
    if rc == 0:
        tally_record(payload)
        emit_pretool("allow", "noti: plan approved from toast")
    return 0


def hook_pretooluse(payload: dict) -> int:
    cfg = load_config()
    d = evaluate(payload, cfg)
    action = d["action"]
    debug(f"pretooluse {payload.get('tool_name')} -> {action} ({d.get('reason','')})")

    if action == "defer":
        return 0                                  # exit 0, no JSON
    if action == "allow":
        tally_record(payload)
        emit_pretool("allow", d.get("reason", "noti: allowed"))
        return 0
    if action == "deny":
        emit_pretool("deny", d.get("reason", "noti: denied"))
        return 0
    if action == "question":
        return prompt_question(payload, cfg, d)
    if action == "plan":
        return prompt_plan(payload, cfg, d)
    if action == "notice":
        # non-blocking heads-up (complex question set): no decision, just make
        # sure the human knows the terminal is waiting on them
        try:
            toast_summary(d["title"], d["message"], cfg["toast"]["summary_timeout_seconds"],
                          cfg["toast"]["corner"], kind=d.get("kind", "question"),
                          footer=d.get("footer", ""))
        except Exception as e:
            debug(f"notice toast failed: {e}")
        return 0

    # action == "prompt": show the toast.
    slot = acquire_slot()
    try:
        rc, label = toast_ask(d["title"], d["message"], ["Yes", "Always", "No"],
                              cfg["toast"]["ask_timeout_seconds"], cfg["toast"]["corner"], slot,
                              hotkeys=bool(cfg["toast"].get("hotkeys", True)),
                              kind=d.get("kind", ""), project=d.get("project", ""))
    except Exception as e:
        debug(f"toast failed: {e}")
        emit_pretool("ask", "noti: toast unavailable, asking in terminal")
        return 0
    finally:
        release_slot(slot)

    choice = label.lower()
    if choice == "yes":
        tally_record(payload)
        emit_pretool("allow", "noti: approved")
    elif choice == "always":
        rule = make_rule(payload.get("tool_name", ""), payload.get("tool_input", {}) or {}, cfg)
        if rule:
            try:
                write_rule(rule, payload, cfg)
            except Exception as e:
                debug(f"write_rule failed: {e}")
        tally_record(payload)
        emit_pretool("allow", f"noti: always-allowed [{rule}]" if rule else "noti: approved")
    elif choice == "no":
        emit_pretool("deny", "noti: denied by user")
    else:
        # rc 124 (timeout) or dismissed -> hand back to Claude's terminal prompt
        emit_pretool("ask", "noti: no response, asking in terminal")
    return 0


def write_rule(rule: str, payload: dict, cfg: dict) -> None:
    cwd = payload.get("cwd") or os.getcwd()
    scope = cfg["approval"]["rule_scope"]
    if scope == "global":
        target = Path.home() / ".claude" / "settings.json"
    elif scope == "project":
        target = Path(cwd) / ".claude" / "settings.json"
    else:
        target = Path(cwd) / ".claude" / "settings.local.json"
    with locked("rules.lock"):
        if target.exists():
            try:
                with open(target) as f:
                    data = json.load(f)
            except Exception as e:
                # NEVER overwrite a file we can't parse — that would wipe the
                # user's real settings (including their deny rules). Abort.
                debug(f"refusing to write rule: {target} is unparseable: {e}")
                return
            if not isinstance(data, dict):
                debug(f"refusing to write rule: {target} is not a JSON object")
                return
            shutil.copy2(target, target.with_suffix(target.suffix + ".noti-prev"))
        else:
            data = {}
        allow = data.setdefault("permissions", {}).setdefault("allow", [])
        if rule not in allow:
            allow.append(rule)
            atomic_write_json(target, data)
    debug(f"wrote rule {rule} -> {target}")


def hook_stop(payload: dict) -> int:
    cfg = load_config()
    if not cfg["summary"]["enabled"]:
        return 0
    msg = payload.get("last_assistant_message") \
        or last_message_from_transcript(payload.get("transcript_path") or "")
    body = clean_summary(msg, cfg["summary"]["max_chars"])
    tline = format_tally(tally_read_and_clear(payload.get("session_id", "default"))) \
        if cfg["summary"]["show_tally"] else ""
    if not body and not tline:
        return 0                                  # nothing worth a toast
    title = os.path.basename((payload.get("cwd") or "").rstrip("/")) or "Claude Code"
    try:
        toast_summary(title, body, cfg["toast"]["summary_timeout_seconds"],
                      cfg["toast"]["corner"], footer=tline)
    except Exception as e:
        debug(f"summary toast failed: {e}")
    return 0

