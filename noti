def emit_pretool(decision: str, reason: str, updated_input: dict | None = None) -> None:
    out = {
        "hookEventName": "PreToolUse",
        "permissionDecision": decision,
        "permissionDecisionReason": reason,
    }
    # updatedInput (allow only) is how a hook hands Claude Code pre-collected
    # AskUserQuestion answers — the same channel its own permission UI uses.
    # A Claude Code too old to know the field just ignores it and asks in the
    # terminal: degraded, never wrong.
    if updated_input is not None:
        out["updatedInput"] = updated_input
    print(json.dumps({"hookSpecificOutput": out}))


def prompt_question(payload: dict, cfg: dict, d: dict) -> int:
    """Toast each question in the call in turn — one card per question, with
    an "i of n" eyebrow when there are several — and hand every click back as
    pre-collected `answers` via updatedInput, so the terminal UI never
    appears. ALL-or-nothing: `answers` marks the whole call answered (partial-
    dict behavior is undocumented), so Esc / timeout / any error on ANY card
    discards everything collected so far and emits NO decision — the terminal
    UI asks the full set fresh (it alone owns the multiSelect / 5+ option /
    duplicate-question shapes). Free-text "Other" is card-native when
    approval.question_other is on: the binary's Other row submits typed text
    as rc == RC_OTHER with the answer on stdout — the one place stdout is the
    answer. The set shares ONE deadline (ask_timeout_seconds
    total; each card's drain shows what's actually left) because the installed
    hook timeout (ask_timeout + 30, sized for a single card) blocks the tool
    call outright when exceeded — per-card budgets would blow through it."""
    items = d.get("items") or []
    n = len(items)
    if not n:
        return 0
    # floor the budget at 4s so a pathological ask_timeout config (<= 3s)
    # still shows the first card briefly instead of silently skipping straight
    # to the terminal with no visual signal at all
    deadline = time.monotonic() + max(float(cfg["toast"]["ask_timeout_seconds"]), 4.0)
    allow_other = bool(cfg["approval"].get("question_other", True))
    answers = {}
    attach = _attach_prompts(cfg)
    slot = None if attach else acquire_slot()
    try:
        for i, item in enumerate(items):
            remaining = deadline - time.monotonic()
            if remaining < 3:           # too little time left to read a card
                return 0
            project = d.get("project", "")
            if n > 1:
                project = f"{project} · {i + 1} of {n}" if project else f"{i + 1} of {n}"
            rc, typed = toast_ask(item["title"], item["message"], item["buttons"],
                                  remaining, cfg["toast"]["corner"], slot,
                                  hotkeys=bool(cfg["toast"].get("hotkeys", True)),
                                  kind="question", project=project,
                                  # full labels + descriptions ride in env for
                                  # the list layout; the footer advertises the
                                  # terminal escape hatch
                                  options=item["options"], descriptions=item["descriptions"],
                                  other=allow_other,
                                  footer="esc · answer in terminal",
                                  attach=attach,
                                  pet_dir=pet_state_dir(cfg) if attach else None)
            if 0 <= rc < len(item["options"]):
                answers[item["question"]] = item["options"][rc]  # index -> EXACT raw label
            elif rc == RC_OTHER and allow_other:
                # The ONE place stdout is the answer. allow_other re-check is
                # load-bearing: with the kill-switch off (or a stray NOTI_OTHER
                # export / hostile binary) the row was never offered, so rc=10
                # must stay in the junk bucket below. Strip C0 controls first —
                # a single-line field can't TYPE them, they only arrive by
                # paste — then outer whitespace. Whitespace-only is NOT an
                # answer: spike-observed (Claude Code 2.1.198), an empty
                # answers value doesn't error upstream, it silently marks the
                # question unanswered and the terminal never re-asks — the
                # question would be LOST. Emitting nothing hands the whole set
                # back to the terminal picker instead.
                typed = re.sub(r"[\x00-\x08\x0b\x0c\x0e-\x1f\x7f]", "", typed).strip()
                if not typed:
                    return 0
                # never trunc()/_display_line() here: display helpers must not
                # touch an answer
                answers[item["question"]] = typed
            else:
                return 0    # esc / timeout / junk rc / sentinel-without-opt-in
            if i < n - 1 and slot is not None:
                # the card's own atexit deleted the slot file; re-claim the
                # slot before the next card spawns, or a concurrent session
                # slides into the gap (two cards overlaying at one position)
                # and the release below would unlink THEIR live claim.
                # Attached cards (slot is None) grow from the pet, not the
                # column, so there is no slot file to re-touch.
                try:
                    (SLOT_DIR / f"slot-{slot}").touch()
                except Exception:
                    pass
    except Exception as e:
        debug(f"question toast failed: {e}")
        return 0
    finally:
        if slot is not None:
            release_slot(slot)
    tinput = dict(payload.get("tool_input") or {})
    tinput["answers"] = answers
    tally_record(payload)
    pet_record(payload, cfg, "running")
    emit_pretool("allow", "noti: question answered from toast", updated_input=tinput)
    return 0


def prompt_plan(payload: dict, cfg: dict, d: dict) -> int:
    """Toast a plan-ready card. Approve is the fast path (Claude proceeds; the
    implementation edits/commands still go through noti's approval toasts).
    View / Esc / timeout emits NO decision — the terminal's plan UI, which can
    actually show the whole plan and take feedback, handles it."""
    attach = _attach_prompts(cfg)
    slot = None if attach else acquire_slot()
    try:
        rc, _ = toast_ask(d["title"], d["message"], ["Approve", "View"],
                          cfg["toast"]["ask_timeout_seconds"], cfg["toast"]["corner"], slot,
                          hotkeys=bool(cfg["toast"].get("hotkeys", True)),
                          kind="plan", project=d.get("project", ""),
                          attach=attach, pet_dir=pet_state_dir(cfg) if attach else None)
    except Exception as e:
        debug(f"plan toast failed: {e}")
        return 0
    finally:
        if slot is not None:
            release_slot(slot)
    if rc == 0:
        tally_record(payload)
        pet_record(payload, cfg, "running")
        emit_pretool("allow", "noti: plan approved from toast")
    return 0


def hook_pretooluse(payload: dict) -> int:
    cfg = load_config()
    d = evaluate(payload, cfg)
    action = d["action"]
    debug(f"pretooluse {payload.get('tool_name')} -> {action} ({d.get('reason','')})")
    pet_record(payload, cfg, "waiting" if action in ("prompt", "question", "plan", "notice") else "running")

    if action == "defer":
        return 0                                  # exit 0, no JSON
    if action == "allow":
        tally_record(payload)
        emit_pretool("allow", d.get("reason", "noti: allowed"))
        return 0
    if action == "deny":
        emit_pretool("deny", d.get("reason", "noti: denied"))
        return 0
    if action == "question":
        return prompt_question(payload, cfg, d)
    if action == "plan":
        return prompt_plan(payload, cfg, d)
    if action == "notice":
        # non-blocking heads-up (complex question set): no decision, just make
        # sure the human knows the terminal is waiting on them
        try:
            toast_summary(d["title"], d["message"], cfg["toast"]["summary_timeout_seconds"],
                          cfg["toast"]["corner"], kind=d.get("kind", "question"),
                          footer=d.get("footer", ""))
        except Exception as e:
            debug(f"notice toast failed: {e}")
        return 0

    # action == "prompt": show the toast. Offer "Always" only when make_rule
    # can actually mint a rule for this exact call: where minting refuses
    # (trailing *, multiline/oversized commands), the button would LOOK like a
    # standing grant while silently downgrading to a one-time Yes — a button
    # that does less than it says is a lie. Dispatch below is by label, so a
    # two-button card needs no exit-code remapping.
    mintable = make_rule(payload.get("tool_name", ""),
                         payload.get("tool_input", {}) or {}, cfg) is not None
    # Attached prompts grow out of the pet at its spot; unattached ones join the
    # corner column. Only the corner path needs a slot (attached cards don't
    # stack there), so acquire one only when not attaching.
    attach = _attach_prompts(cfg)
    slot = None if attach else acquire_slot()
    try:
        rc, label = toast_ask(d["title"], d["message"],
                              ["Yes", "Always", "No"] if mintable else ["Yes", "No"],
                              cfg["toast"]["ask_timeout_seconds"], cfg["toast"]["corner"], slot,
                              hotkeys=bool(cfg["toast"].get("hotkeys", True)),
                              kind=d.get("kind", ""), project=d.get("project", ""),
                              attach=attach, pet_dir=pet_state_dir(cfg) if attach else None)
    except Exception as e:
        debug(f"toast failed: {e}")
        emit_pretool("ask", "noti: toast unavailable, asking in terminal")
        return 0
    finally:
        if slot is not None:
            release_slot(slot)

    choice = label.lower()
    if choice == "yes":
        tally_record(payload)
        pet_record(payload, cfg, "running")
        emit_pretool("allow", "noti: approved")
    elif choice == "always":
        rule = make_rule(payload.get("tool_name", ""), payload.get("tool_input", {}) or {}, cfg)
        if rule:
            try:
                write_rule(rule, payload, cfg)
            except Exception as e:
                debug(f"write_rule failed: {e}")
        tally_record(payload)
        pet_record(payload, cfg, "running")
        emit_pretool("allow", f"noti: always-allowed [{rule}]" if rule else "noti: approved")
    elif choice == "no":
        pet_record(payload, cfg, "running")
        emit_pretool("deny", "noti: denied by user")
    else:
        # rc 124 (timeout) or dismissed -> hand back to Claude's terminal prompt
        emit_pretool("ask", "noti: no response, asking in terminal")
    return 0


def write_rule(rule: str, payload: dict, cfg: dict) -> None:
    cwd = payload.get("cwd") or os.getcwd()
    scope = cfg["approval"]["rule_scope"]
    if scope == "global":
        target = Path.home() / ".claude" / "settings.json"
    elif scope == "project":
        target = Path(cwd) / ".claude" / "settings.json"
    else:
        target = Path(cwd) / ".claude" / "settings.local.json"
    with locked("rules.lock"):
        if target.exists():
            try:
                with open(target) as f:
                    data = json.load(f)
            except Exception as e:
                # NEVER overwrite a file we can't parse — that would wipe the
                # user's real settings (including their deny rules). Abort.
                debug(f"refusing to write rule: {target} is unparseable: {e}")
                return
            if not isinstance(data, dict):
                debug(f"refusing to write rule: {target} is not a JSON object")
                return
            shutil.copy2(target, target.with_suffix(target.suffix + ".noti-prev"))
        else:
            data = {}
        allow = data.setdefault("permissions", {}).setdefault("allow", [])
        if rule not in allow:
            allow.append(rule)
            atomic_write_json(target, data)
    debug(f"wrote rule {rule} -> {target}")


def hook_stop(payload: dict) -> int:
    cfg = load_config()
    pet_record(payload, cfg, "done")
    pet_sweep(cfg)                                 # reap long-dead session files
    if not cfg["summary"]["enabled"]:
        return 0
    msg = payload.get("last_assistant_message") \
        or last_message_from_transcript(payload.get("transcript_path") or "")
    body = clean_summary(msg, cfg["summary"]["max_chars"])
    tline = format_tally(tally_read_and_clear(payload.get("session_id", "default"))) \
        if cfg["summary"]["show_tally"] else ""
    if not body and not tline:
        return 0                                  # nothing worth a toast
    title = os.path.basename((payload.get("cwd") or "").rstrip("/")) or "Claude Code"
    try:
        toast_summary(title, body, cfg["toast"]["summary_timeout_seconds"],
                      cfg["toast"]["corner"], footer=tline)
    except Exception as e:
        debug(f"summary toast failed: {e}")
    return 0

